@page "/counter"

<h1>Counter</h1>

<p role="status" data-testid="count">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount" data-testid="ctnbtn">Click me</button>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
